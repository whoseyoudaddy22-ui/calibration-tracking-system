# Copy this file to .env and fill in real values before running the app.
#
#   cp .env.example .env
#
# See README.md for full setup steps.

# SQLite connection string used by Prisma.
DATABASE_URL="file:./dev.db"

# NextAuth session/JWT signing secret.
# Generate one with: npx auth secret   (or: openssl rand -base64 32)
AUTH_SECRET=""

# Admin user created by `npm run db:seed`. Change these before a real demo.
SEED_ADMIN_USERNAME="admin"
SEED_ADMIN_PASSWORD="ChangeMe123!"
