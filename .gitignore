# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

/src/generated/prisma

# local sqlite database (run `npx prisma migrate deploy && npm run db:seed` to recreate)
/dev.db
/dev.db-journal
/dev.db-wal
/dev.db-shm

# integration test sqlite database (created/removed automatically by `npm run test`)
/test-integration.db
/test-integration.db-journal
/test-integration.db-wal
/test-integration.db-shm

# e2e test sqlite database + Playwright output (created/removed automatically by `npm run test:e2e`)
/e2e-test.db
/e2e-test.db-journal
/e2e-test.db-wal
/e2e-test.db-shm
/test-results/
/playwright-report/
/playwright/.cache/
